<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
  "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
  "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>
  <!-- Suppress Javadoc requirements on the Spring bootstrap class (infrastructure, not API). -->
  <suppress files="ServerApplication\.java" checks="SummaryJavadoc"/>
  <suppress files="ServerApplication\.java" checks="MissingJavadocType"/>
  <suppress files="ServerApplication\.java" checks="MissingJavadocMethod"/>
</suppressions>
